<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoctorApp.Views.LoginPage"
             Title="Iniciar Sesión">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center" HorizontalOptions="Fill">

        <!-- Título -->
        <Label 
            Text="Doctor App"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalTextAlignment="Center"
            Margin="0,0,0,30" />

        <!-- Usuario -->
        <Label Text="Usuario" FontSize="14" FontAttributes="Bold" />
        <Entry 
            Placeholder="Ingrese su usuario"
            Text="{Binding Usuario}" 
            FontSize="14" />

        <!-- Contraseña -->
        <Label Text="Contraseña" FontSize="14" FontAttributes="Bold" />
        <Entry 
            Placeholder="Ingrese su contraseña"
            Text="{Binding Contrasena}"
            IsPassword="True"
            FontSize="14" />

        <!-- Botón Login -->
        <Button 
            Text="Iniciar Sesión"
            Command="{Binding LoginCommand}"
            FontSize="16"
            FontAttributes="Bold"
            Padding="10"
            Margin="0,20,0,0" />

        <!-- Mensaje de Estado -->
        <Label 
            Text="{Binding MensajeEstado}"
            FontSize="12"
            TextColor="Red"
            HorizontalTextAlignment="Center"
            IsVisible="{Binding MostrarMensaje}" />

        <!-- Indicador de Carga -->
        <ActivityIndicator 
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Margin="0,20,0,0" />

    </VerticalStackLayout>

</ContentPage>
