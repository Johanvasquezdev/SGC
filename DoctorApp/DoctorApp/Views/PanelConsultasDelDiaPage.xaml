<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoctorApp.Views.PanelConsultasDelDiaPage"
             Title="Panel de Consultas"
             BackgroundColor="#F5F7FA">
    <VerticalStackLayout Padding="0" Spacing="0">
        <Frame CornerRadius="0" Padding="20" HasShadow="False" BackgroundColor="#6B46C1" Margin="0">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="🏥" FontSize="28"/>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                        <Label Text="Panel de Consultas del Día" FontSize="18" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding MedicoActual.NombreCompleto}" FontSize="12" TextColor="#E9D5FF"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <Label Text="{Binding MedicoActual.Especialidad}" FontSize="11" TextColor="#D8B4FE" Margin="38,0,0,0"/>
            </VerticalStackLayout>
        </Frame>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">
                <HorizontalStackLayout Spacing="10">
                    <Frame CornerRadius="12" Padding="12" HasShadow="True" BackgroundColor="White" HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding TotalConsultas, StringFormat='{0}'}" FontSize="24" FontAttributes="Bold" TextColor="#6B46C1" HorizontalOptions="Center"/>
                            <Label Text="Total" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame CornerRadius="12" Padding="12" HasShadow="True" BackgroundColor="White" HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding ConsultasEnCurso, StringFormat='{0}'}" FontSize="24" FontAttributes="Bold" TextColor="#3B82F6" HorizontalOptions="Center"/>
                            <Label Text="En Curso" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame CornerRadius="12" Padding="12" HasShadow="True" BackgroundColor="White" HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding ConsultasCompletadas, StringFormat='{0}'}" FontSize="24" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            <Label Text="Completadas" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                    <Frame CornerRadius="12" Padding="12" HasShadow="True" BackgroundColor="White" HorizontalOptions="FillAndExpand">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding ConsultasEsperando, StringFormat='{0}'}" FontSize="24" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                            <Label Text="Esperando" FontSize="11" TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Frame>
                </HorizontalStackLayout>
                <Frame CornerRadius="12" Padding="15" HasShadow="True" BackgroundColor="White">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Buscar Paciente" FontSize="12" FontAttributes="Bold" TextColor="#1F2937"/>
                        <Entry Placeholder="Nombre o Cédula..." Text="{Binding BusquedaPaciente}" BackgroundColor="#F3F4F6" TextColor="#1F2937" PlaceholderColor="#9CA3AF"/>
                    </VerticalStackLayout>
                </Frame>
                <Label Text="Pacientes Citados" FontSize="16" FontAttributes="Bold" TextColor="#1F2937"/>
                <CollectionView ItemsSource="{Binding ConsultasFiltradas}" SelectionMode="Single" SelectedItem="{Binding PacienteSeleccionado}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="12" Padding="15" Margin="0,8" HasShadow="True" BackgroundColor="White">
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="10">
                                        <VerticalStackLayout WidthRequest="70" VerticalOptions="Center">
                                            <Label Text="{Binding HoraFormato}" FontSize="20" FontAttributes="Bold" TextColor="#1F2937" HorizontalOptions="Center"/>
                                            <Label Text="{Binding DuracionDesdeAhora}" FontSize="10" TextColor="#9CA3AF" HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="3">
                                            <Label Text="{Binding NombreCompleto}" FontSize="14" FontAttributes="Bold" TextColor="#1F2937"/>
                                            <Label Text="{Binding Motivo}" FontSize="12" TextColor="#6B7280"/>
                                        </VerticalStackLayout>
                                        <Frame CornerRadius="8" Padding="10,6" HasShadow="False" BackgroundColor="{Binding ColorEstado}" VerticalOptions="Center">
                                            <Label Text="{Binding TextoEstado}" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>
                                    </HorizontalStackLayout>
                                    <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>
                                    <VerticalStackLayout Spacing="8">
                                        <HorizontalStackLayout Spacing="15">
                                            <VerticalStackLayout HorizontalOptions="FillAndExpand">
                                                <Label Text="👤 Cédula" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                                <Label Text="{Binding Cedula}" FontSize="11" TextColor="#1F2937" FontAttributes="Bold"/>
                                            </VerticalStackLayout>
                                            <VerticalStackLayout HorizontalOptions="FillAndExpand">
                                                <Label Text="📅 Edad" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                                <Label Text="{Binding Edad, StringFormat='{0} años'}" FontSize="11" TextColor="#1F2937" FontAttributes="Bold"/>
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="📱" FontSize="12" VerticalOptions="Center"/>
                                            <Label Text="{Binding Telefono}" FontSize="11" TextColor="#1F2937" VerticalOptions="Center" HorizontalOptions="FillAndExpand"/>
                                        </HorizontalStackLayout>
                                        <VerticalStackLayout>
                                            <Label Text="⚕️ Antecedentes Relevantes" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                            <Label Text="{Binding AntecedentesRelevantes}" FontSize="11" TextColor="#374151" LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                    <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>
                                    <VerticalStackLayout Spacing="8">
                                        <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IniciarConsultaCommand}" CommandParameter="{Binding .}" Text="🏥 Iniciar Consulta" BackgroundColor="#6B46C1" TextColor="White" FontSize="12" FontAttributes="Bold" CornerRadius="6" IsEnabled="{Binding Estado, Converter={StaticResource PuedoIniciarConverter}}"/>
                                        <HorizontalStackLayout Spacing="8">
                                            <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CompletarConsultaCommand}" CommandParameter="{Binding .}" Text="✅ Completar" BackgroundColor="#10B981" TextColor="White" FontSize="11" FontAttributes="Bold" CornerRadius="6" HorizontalOptions="FillAndExpand"/>
                                            <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarcarNoPrestoCommand}" CommandParameter="{Binding .}" Text="❌ No Presentó" BackgroundColor="#EF4444" TextColor="White" FontSize="11" FontAttributes="Bold" CornerRadius="6" HorizontalOptions="FillAndExpand"/>
                                            <Button Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ReprogramarConsultaCommand}" CommandParameter="{Binding .}" Text="📅 Reprogramar" BackgroundColor="#8B5CF6" TextColor="White" FontSize="11" FontAttributes="Bold" CornerRadius="6" HorizontalOptions="FillAndExpand"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Label Text="No hay consultas para mostrar" FontSize="13" TextColor="#9CA3AF" HorizontalOptions="Center" VerticalOptions="CenterAndExpand" IsVisible="{Binding ConsultasFiltradas.Count, Converter={StaticResource IntToNegativeBoolConverter}}"/>
            </VerticalStackLayout>
        </ScrollView>
    </VerticalStackLayout>
</ContentPage>
