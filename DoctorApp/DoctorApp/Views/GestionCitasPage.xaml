<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoctorApp.Views.GestionCitasPage"
             Title="Gestión de Citas"
             BackgroundColor="#F5F7FA">

    <VerticalStackLayout Padding="20" Spacing="15">
        <!-- Header -->
        <VerticalStackLayout Spacing="5">
            <Label Text="Mis Citas Médicas" 
                   FontSize="22" FontAttributes="Bold" 
                   TextColor="#1F2937"/>
            <Label Text="Administra y actualiza el estado de tus citas" 
                   FontSize="13" 
                   TextColor="#6B7280"/>
        </VerticalStackLayout>

        <!-- Filtros -->
        <Frame CornerRadius="12" Padding="15" HasShadow="True" BackgroundColor="White">
            <VerticalStackLayout Spacing="12">
                <Label Text="Filtrar Citas" FontSize="13" FontAttributes="Bold" TextColor="#1F2937"/>

                <!-- Selector de Estado -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Estado" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                    <Picker ItemsSource="{Binding EstadosDisponibles}"
                           SelectedItem="{Binding EstadoFiltro}"
                           BackgroundColor="#F3F4F6"
                           TextColor="#1F2937"/>
                </VerticalStackLayout>

                <!-- Selector de Fecha -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Fecha" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                    <DatePicker Date="{Binding FechaFiltro}"
                               BackgroundColor="#F3F4F6"
                               Format="dd/MM/yyyy"/>
                </VerticalStackLayout>

                <!-- Búsqueda de Paciente -->
                <VerticalStackLayout Spacing="5">
                    <Label Text="Buscar Paciente" FontSize="11" FontAttributes="Bold" TextColor="#374151"/>
                    <Entry Placeholder="Nombre o Cédula..."
                          Text="{Binding BusquedaPaciente}"
                          BackgroundColor="#F3F4F6"
                          TextColor="#1F2937"
                          PlaceholderColor="#9CA3AF"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Contador de Resultados -->
        <Label Text="{Binding CitasFiltradas.Count, StringFormat='📋 {0} cita(s) encontrada(s)'}" 
               FontSize="12" 
               TextColor="#6B7280"
               Margin="0,5,0,5"/>

        <!-- Listado de Citas -->
        <CollectionView ItemsSource="{Binding CitasFiltradas}" 
                   SelectionMode="Single"
                   SelectedItem="{Binding CitaSeleccionada}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame CornerRadius="12" Padding="15" Margin="0,8" 
                       HasShadow="True" BackgroundColor="White">
                    <VerticalStackLayout Spacing="12">
                            <!-- Encabezado: Hora y Estado -->
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
                                <!-- Hora -->
                                <VerticalStackLayout WidthRequest="70" VerticalOptions="Center">
                                    <Label Text="{Binding FechaHora, StringFormat='🕐 {0:HH:mm}'}" 
                                           FontSize="16" FontAttributes="Bold" 
                                           TextColor="#1F2937"/>
                                    <Label Text="{Binding DuracionMinutos, StringFormat='{0}min'}" 
                                           FontSize="10" 
                                           TextColor="#9CA3AF"/>
                                </VerticalStackLayout>

                                <!-- Info Principal -->
                                <VerticalStackLayout HorizontalOptions="FillAndExpand" Spacing="2">
                                    <Label Text="{Binding Paciente.NombreCompleto}" 
                                           FontSize="14" FontAttributes="Bold" 
                                           TextColor="#1F2937"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Motivo}" 
                                           FontSize="12" 
                                           TextColor="#6B7280"/>
                                </VerticalStackLayout>

                                <!-- Badge Estado -->
                                <Frame CornerRadius="6" Padding="8,4" 
                                       HasShadow="False"
                                       BackgroundColor="{Binding Estado, Converter={StaticResource EstadoCitaColorConverter}}"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding Estado}" 
                                           FontSize="10" FontAttributes="Bold" 
                                           TextColor="White"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>
                            </HorizontalStackLayout>

                            <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>

                            <!-- Información del Paciente -->
                            <HorizontalStackLayout Spacing="15" IsVisible="{Binding CitaSeleccionada, Converter={StaticResource EqualsConverter}}">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                    <Label Text="👤 Paciente" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                    <Label Text="{Binding Paciente.Cedula}" FontSize="11" TextColor="#1F2937"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                    <Label Text="📱 Teléfono" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                    <Label Text="{Binding Paciente.Telefono}" FontSize="11" TextColor="#1F2937"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                    <Label Text="📧 Email" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                    <Label Text="{Binding Paciente.Email}" FontSize="11" TextColor="#1F2937" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>

                            <!-- Notas -->
                            <VerticalStackLayout Spacing="5" IsVisible="{Binding Notas, Converter={StaticResource StringToBoolConverter}}">
                                <Label Text="📝 Notas" FontSize="10" FontAttributes="Bold" TextColor="#6B7280"/>
                                <Label Text="{Binding Notas}" FontSize="11" TextColor="#374151" LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" BackgroundColor="#E5E7EB"/>

                            <!-- Botones de Acción (aparecen si está seleccionada) -->
                            <HorizontalStackLayout Spacing="8" IsVisible="{Binding CitaSeleccionada, Converter={StaticResource EqualsConverter}}">
                                <Button Command="{Binding ConfirmarCitaCommand}" 
                                       Text="✅ Confirmar"
                                       BackgroundColor="#10B981"
                                       TextColor="White"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="10,8"
                                       CornerRadius="6"
                                       HorizontalOptions="FillAndExpand"
                                       IsEnabled="{Binding Estado, Converter={StaticResource PuedoConfirmarConverter}}"/>

                                <Button Command="{Binding CompletarCitaCommand}" 
                                       Text="✔️ Completar"
                                       BackgroundColor="#3B82F6"
                                       TextColor="White"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="10,8"
                                       CornerRadius="6"
                                       HorizontalOptions="FillAndExpand"/>

                                <Button Command="{Binding CancelarCitaCommand}" 
                                       Text="✕ Cancelar"
                                       BackgroundColor="#EF4444"
                                       TextColor="White"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       Padding="10,8"
                                       CornerRadius="6"
                                       HorizontalOptions="FillAndExpand"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Mensaje vacío -->
        <Label Text="No hay citas que coincidan con los filtros seleccionados"
               FontSize="13"
               TextColor="#9CA3AF"
               HorizontalOptions="Center"
               VerticalOptions="CenterAndExpand"
               IsVisible="{Binding CitasFiltradas.Count, Converter={StaticResource IntToNegativeBoolConverter}}"/>
    </VerticalStackLayout>
</ContentPage>
